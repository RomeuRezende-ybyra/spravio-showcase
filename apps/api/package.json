{
  "name": "@spravio/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file .env src/server.ts | pino-pretty",
    "build": "tsc",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "prisma": "prisma",
    "db:seed": "tsx --env-file .env prisma/seed.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.82.0",
    "@fastify/cors": "^10.0.0",
    "@fastify/helmet": "^13.0.0",
    "@fastify/jwt": "^10.0.0",
    "@fastify/rate-limit": "^10.1.1",
    "@prisma/client": "^6.0.0",
    "@sentry/node": "^10.47.0",
    "@slack/web-api": "^7.14.1",
    "@spravio/types": "workspace:*",
    "@spravio/utils": "workspace:*",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.0.0",
    "fastify": "^5.0.0",
    "fastify-plugin": "^5.0.0",
    "ioredis": "^5.4.0",
    "jsonwebtoken": "^9.0.3",
    "p-limit": "^6.0.0",
    "stripe": "^20.4.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "pino-pretty": "^13.0.0",
    "prisma": "^6.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
