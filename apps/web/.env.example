NEXTAUTH_URL=http://localhost:3003

# IMPORTANTE: Em produção, use um secret forte (64+ bytes random base64)
# Gerar: node -e "console.log(require('crypto').randomBytes(64).toString('base64'))"
NEXTAUTH_SECRET=change-me-in-production-use-64-bytes-random-base64

NEXT_PUBLIC_API_URL=http://localhost:3002

# Sentry (optional)
NEXT_PUBLIC_SENTRY_DSN=
