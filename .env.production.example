# ─── PRODUCTION ENVIRONMENT ───────────────────────────────────────────────────
# Copy this file to .env.production and fill in the values

# ─── DOMAIN ───────────────────────────────────────────────────────────────────
DOMAIN=spravio.io

# ─── CORS ─────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=https://spravio.io,https://www.spravio.io,https://api.spravio.io

# ─── DOCKER IMAGES ────────────────────────────────────────────────────────────
# IMPORTANT: Use full GHCR registry paths
API_IMAGE=ghcr.io/your-org/spravio-api
WEB_IMAGE=ghcr.io/your-org/spravio-web
IMAGE_TAG=latest

# ─── DATABASE ─────────────────────────────────────────────────────────────────
POSTGRES_USER=spravio
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=spravio_production

# Connection pool settings: connection_limit=20, pool_timeout=20s
# Adjust based on your server resources and expected load
DATABASE_URL=postgresql://spravio:CHANGE_ME_STRONG_PASSWORD@postgres:5432/spravio_production?connection_limit=20&pool_timeout=20&connect_timeout=10

# ─── REDIS ────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD

# ─── SECRETS ──────────────────────────────────────────────────────────────────
JWT_SECRET=CHANGE_ME_JWT_SECRET_64_CHARS_RANDOM
PORTAL_SECRET=CHANGE_ME_PORTAL_SECRET_32_CHARS_RANDOM
NEXTAUTH_SECRET=CHANGE_ME_NEXTAUTH_SECRET_32_CHARS_RANDOM

# ─── INTEGRATIONS (Optional) ──────────────────────────────────────────────────
JIRA_BASE_URL=
JIRA_EMAIL=
JIRA_API_TOKEN=
JIRA_CLOUD_ID=
GH_INTEGRATION_TOKEN=
GITHUB_ORG=

# ─── STRIPE (Optional) ────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret_here

# ─── SENTRY (Optional) ────────────────────────────────────────────────────────
# Get DSNs from https://sentry.io after creating projects
# API project: spravio-api (Node.js)
SENTRY_DSN_API=https://xxxxx@o1234567.ingest.sentry.io/API_PROJECT_ID

# Web project: spravio-web (Next.js)
NEXT_PUBLIC_SENTRY_DSN=https://yyyyy@o1234567.ingest.sentry.io/WEB_PROJECT_ID

# Auth token for uploading source maps (optional, for better stack traces)
SENTRY_AUTH_TOKEN=

# ─── GENERATE SECRETS ─────────────────────────────────────────────────────────
# Run these commands to generate secure random secrets:
#   openssl rand -hex 32  # For 64-char secrets
#   openssl rand -hex 16  # For 32-char secrets
