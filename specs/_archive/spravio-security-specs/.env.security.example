# ========================================
# Spravio — Security & LGPD env vars
# ========================================
# Adicione estas variáveis ao seu .env conforme implementa cada spec.
# NUNCA commite valores reais no git.

# -----------------------------------
# Spec 023: Token Encryption at Rest
# -----------------------------------
# Gere com: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# Backup offline em cofre físico — perder = perder acesso a todos os tokens
ENCRYPTION_MASTER_KEY_V1=<base64 de 32 bytes>
# Durante rotação:
# ENCRYPTION_MASTER_KEY_V2=<nova chave>
ENCRYPTION_ACTIVE_KEY=v1

# -----------------------------------
# Spec 024: Log Sanitization
# -----------------------------------
LOG_LEVEL=info
# Em produção SEMPRE info ou warn. trace/debug só em dev local.

SENTRY_DSN=<seu dsn do Sentry>
SENTRY_ENVIRONMENT=production

# -----------------------------------
# Spec 026: Data Retention & Deletion
# -----------------------------------
DATA_DELETION_GRACE_DAYS=30
BURNDOWN_RETENTION_YEARS=2
ISSUE_BODY_RETENTION_YEARS=1
WEBHOOK_PAYLOAD_RETENTION_DAYS=90

# -----------------------------------
# Spec 028: Audit Log
# -----------------------------------
AUDIT_LOG_RETENTION_YEARS=5
AUDIT_BRUTEFORCE_WINDOW_MINUTES=5
AUDIT_BRUTEFORCE_THRESHOLD=5

# -----------------------------------
# Spec 029: Scope Minimization (OAuth)
# -----------------------------------
# GitHub OAuth App: https://github.com/settings/developers
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=

# GitLab OAuth: https://gitlab.com/-/profile/applications
GITLAB_OAUTH_CLIENT_ID=
GITLAB_OAUTH_CLIENT_SECRET=

# Slack App: https://api.slack.com/apps
SLACK_OAUTH_CLIENT_ID=
SLACK_OAUTH_CLIENT_SECRET=

APP_URL=https://spravio.io

# -----------------------------------
# Spec 030: Data Export & Portability
# -----------------------------------
# S3-compatible storage para ZIPs de export
AWS_REGION=us-east-1
EXPORT_BUCKET=spravio-exports
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

EXPORT_DOWNLOAD_TTL_HOURS=24
EXPORT_CLEANUP_DAYS=7
EXPORT_RATE_LIMIT_HOURS=24
