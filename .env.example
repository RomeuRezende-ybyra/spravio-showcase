# ─── Database ───────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5434/trackingproject

# ─── Redis ──────────────────────────────────────────────
REDIS_URL=redis://localhost:6380

# ─── Auth ───────────────────────────────────────────────
# IMPORTANTE: Em produção, use secrets fortes (64+ bytes random base64)
# Gerar: node -e "console.log(require('crypto').randomBytes(64).toString('base64'))"
JWT_SECRET=change-me-in-production-use-64-bytes-random-base64

# ─── Encryption ─────────────────────────────────────────
# Chave para criptografar tokens sensíveis no banco (Jira, GitHub, Azure, etc.)
# Gerar: node -e "console.log(require('crypto').randomBytes(64).toString('base64'))"
ENCRYPTION_KEY=change-me-in-production-use-64-bytes-random-base64

# ─── Jira ───────────────────────────────────────────────
JIRA_BASE_URL=https://yourcompany.atlassian.net
JIRA_EMAIL=your@email.com
JIRA_API_TOKEN=your_token
JIRA_CLOUD_ID=your_cloud_id

# ─── GitHub ─────────────────────────────────────────────
GITHUB_TOKEN=your_github_token
GITHUB_ORG=your_org_name

# ─── App ────────────────────────────────────────────────
PORT=3002
NODE_ENV=development
